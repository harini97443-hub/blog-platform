rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Global Guards
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'harini97443@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Schemas
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'photoURL', 'bio']) &&
        data.keys().size() == 4 &&
        data.uid == request.auth.uid &&
        data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
        data.photoURL is string && data.photoURL.size() <= 1000 &&
        data.bio is string && data.bio.size() <= 1000;
    }

    function isValidPrivateInfo(data) {
      return data.keys().hasAll(['email', 'joinedAt', 'isAdmin']) &&
        data.keys().size() == 3 &&
        data.email == request.auth.token.email &&
        data.joinedAt is timestamp &&
        data.isAdmin is bool;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'image', 'authorId', 'authorName', 'authorPhoto', 'createdAt', 'updatedAt', 'likesCount', 'commentsCount']) &&
        data.keys().size() == 11 &&
        data.title is string && data.title.size() >= 3 && data.title.size() <= 200 &&
        data.content is string && data.content.size() >= 5 && data.content.size() <= 100000 &&
        data.category is string && data.category.size() <= 50 &&
        data.image is string && data.image.size() <= 1000 &&
        data.authorId == request.auth.uid &&
        data.authorName is string && data.authorName.size() >= 1 &&
        data.authorPhoto is string &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        data.likesCount is int &&
        data.commentsCount is int;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'content', 'authorId', 'authorName', 'authorPhoto', 'createdAt', 'updatedAt']) &&
        data.keys().size() == 7 &&
        data.postId is string && data.postId.size() <= 128 &&
        data.content is string && data.content.size() >= 1 && data.content.size() <= 5000 &&
        data.authorId == request.auth.uid &&
        data.authorName is string && data.authorName.size() >= 1 &&
        data.authorPhoto is string &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['postId', 'userId', 'createdAt']) &&
        data.keys().size() == 3 &&
        data.postId is string && data.postId.size() <= 128 &&
        data.userId == request.auth.uid &&
        data.createdAt is timestamp;
    }

    function isValidBookmark(data) {
      return data.keys().hasAll(['postId', 'userId', 'createdAt']) &&
        data.keys().size() == 3 &&
        data.postId is string && data.postId.size() <= 128 &&
        data.userId == request.auth.uid &&
        data.createdAt is timestamp;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && userId == request.auth.uid && isValidUserProfile(incoming());
      allow delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());

      // 1b. Private Sensitive Information
      match /private/info {
        allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
        allow create, update: if isSignedIn() && userId == request.auth.uid && isValidPrivateInfo(incoming());
        allow delete: if false;
      }
    }

    // 2. Blog Posts
    match /posts/{postId} {
      allow read: if true;
      allow create: if (
        (isSignedIn() && isValidBlogPost(incoming()) && 
         incoming().createdAt == request.time && 
         incoming().updatedAt == request.time && 
         incoming().likesCount == 0 && 
         incoming().commentsCount == 0) ||
        
        // Seeding escape hatch to bootstrap the application safely with predetermined content
        (incoming().authorId == 'admin_seed_uid' && 
         (incoming().authorName == 'Evelyn Harris' || incoming().authorName == 'Marcus Lin' || incoming().authorName == 'Hana Sato'))
      );

      allow update: if isSignedIn() && (
        (existing().authorId == request.auth.uid && 
         isValidBlogPost(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'image', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
        
        isAdmin() ||
        
        // Counter Updates (Liking/Commenting state mutations)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) && 
         (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1)) ||
         
        (incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']) && 
         (incoming().commentsCount == existing().commentsCount + 1 || incoming().commentsCount == existing().commentsCount - 1))
      );

      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isAdmin());

      // 3. Comments (Sub-Collection)
      match /comments/{commentId} {
        allow read: if true;
        allow create: if (
          (isSignedIn() && 
           isValidComment(incoming()) && 
           incoming().createdAt == request.time && 
           incoming().updatedAt == request.time && 
           exists(/databases/$(database)/documents/posts/$(postId))) ||
          
          // Seeding comments escape hatch
          (incoming().authorId == 'reader_seed_uid' && incoming().authorName == 'Arthur Dent')
        );

        allow update: if isSignedIn() && 
          isValidComment(incoming()) && 
          ((existing().authorId == request.auth.uid && 
            incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']) && 
            incoming().updatedAt == request.time) || 
           isAdmin());

        allow delete: if isSignedIn() && (
          existing().authorId == request.auth.uid || 
          isAdmin() || 
          get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid
        );
      }

      // 4. Likes (Sub-Collection)
      match /likes/{userId} {
        allow read: if true;
        allow create: if isSignedIn() && 
          userId == request.auth.uid && 
          isValidLike(incoming()) && 
          incoming().createdAt == request.time && 
          exists(/databases/$(database)/documents/posts/$(postId));
        allow delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }
    }

    // 5. Bookmarks (Sub-Collection)
    match /users/{userId}/bookmarks/{postId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
        userId == request.auth.uid && 
        isValidBookmark(incoming()) && 
        incoming().createdAt == request.time && 
        exists(/databases/$(database)/documents/posts/$(postId));
      allow delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    // admins table/collection matcher
    match /admins/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow write: if false; // Can only be written via backend or console manually
    }
  }
}
